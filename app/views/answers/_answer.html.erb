  <!--id нужен чтобы придать каждому ответу id, (и в контроллере добавим якорь при redirecte) если в адресной строке допишем #answer-9 то есть получится (questions/3#answer-9) где # значит якорь, то нас перебросит к этому овтету, просто страницу прокрутит вниз -->
  <article class="mb-3 card" id="answer-<%= answer.id %>">
    <div class="card-body">
      <section class="card-text">
        <small><time datetime="<%= answer.formatted_created_at %>">
          <%= answer.formatted_created_at %>
        </time></small>

    <div class="mt-2 mb-3">
      <%= sanitize answer.body %>
    </div>
      </section>
    <!-- здесь убираем от question @ , и делаем ее локальной, чтобы мы не зависели от того, что ее где то не обьявили, хотя здесь она идет из метода show и доступна во вью show, а ВСЕ ПАРШЕЛЫ ИЗ show имеют доступ также к этой переменной, она передается. Но мы не будем рисковать-->
    <%= link_to 'Edit', edit_question_answer_path(question, answer), 
      class: 'btn btn-info btn-sm' %>
    <%= link_to 'Delete', question_answer_path(question, answer), 
      class: 'btn btn-danger btn-sm', data: {method: :delete, confirm: "Are you sure?"} %>
  </article>