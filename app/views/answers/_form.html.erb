
<!--Можно сразу паршл в паршеле делать. Здесь снизу наш паршел с ошибками-->
<%= render 'shared/errors', object: @answer %>

<%= form_with model:[@question, @answer] do |f| %>
  <div class="mb-3 row">
    <div class="col-sm-2 col-form-label">
      <%= f.label :body %>
    </div>

    <div class="col-sm-10">
      <%= f.text_field :body, class: 'form-control' %>
    </div>
  </div>

  <%= f.submit "Edit answer!", class: 'btn btn-primary' %>
<% end %>