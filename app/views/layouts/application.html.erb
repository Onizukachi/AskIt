<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <!--внизу хелпер вставляем из директории heplers в application-helper.rb, он главный, чтобы для всех страниц работал -->
    <!-- здесь yield не главный, в него подставлять любой другой контент, а тот что внизу страницу, он главный -->
    <title><%= full_title(yield(:page_title)) %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>

  <body>
      <!-- вместо yield должно выводиться главное меню из паршела, с помощью хелпера -->
      <%= yield :main_menu %>

      <main class="container mt-3">
        <% flash.each do |k, v| %>
          <%= tag.div v, class: "alert alert-#{k}", role: 'alert' %>
        <% end %>
        <!-- главный yield вместо него подставядлется содержимое представлений-->
        <%= yield %>
    </main>

  </body>
</html>
